<Window x:Class="SalesPro.Wpf.Views.BuscarProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Producto" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#0F141A"
        Foreground="#E7EDF5">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D7DEE8" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Buscar producto por nombre o código:" FontWeight="SemiBold" FontSize="14" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ProductoBusqueda, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,10,12" />
                <Button Grid.Column="1" Content="Buscar" Command="{Binding BuscarProductosCommand}" VerticalAlignment="Top" Margin="0,5,0,0" />
            </Grid>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ProductosEncontrados}"
                  SelectedItem="{Binding ProductoSeleccionado}"
                  IsReadOnly="True"
                  Background="#121820"
                  Foreground="#E7EDF5"
                  RowBackground="#121820"
                  AlternatingRowBackground="#18202A"
                  HeadersVisibility="Column"
                  Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding CodigoBarra}" Width="100" />
                <DataGridTextColumn Header="Producto" Binding="{Binding NombreEtiqueta}" Width="*" />
                <DataGridTextColumn Header="Stock" Binding="{Binding ExistenciaEnStock}" Width="80" />
                <DataGridTextColumn Header="Precio" Binding="{Binding PrecioNeto, StringFormat=₡{0:N2}}" Width="120" />
                <DataGridCheckBoxColumn Header="IVA" Binding="{Binding TieneImpuesto}" Width="60" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Cantidad:" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox Grid.Column="1" Text="{Binding CantidadProducto, UpdateSourceTrigger=PropertyChanged}" Margin="0" VerticalContentAlignment="Center" />
            
            <TextBlock Grid.Column="2" Text="{Binding Mensaje}" Foreground="#9FB2C8" VerticalAlignment="Center" Margin="15,0,0,0" />

            <Button Grid.Column="3" Content="Cancelar" Click="Cerrar_Click" Margin="0,0,10,0" Background="#26313D" Foreground="#E7EDF5" />
            <Button Grid.Column="4" Content="Agregar Producto" Click="Agregar_Click" Background="#1688F0" Foreground="White" />
        </Grid>
    </Grid>
</Window>
