<UserControl x:Class="SalesPro.Wpf.Views.CuentasBancariasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D7DEE8" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="6" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,7" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="Gestión de cuentas bancarias" FontSize="26" FontWeight="Bold" Foreground="#F3F6FA" Margin="0,0,28,0" />
            <TextBox Width="260" Text="{Binding Buscar, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
            <Button Content="Buscar / recargar" Command="{Binding CargarCommand}" />
            <Button Content="Nueva" Command="{Binding NuevaCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Cuentas}"
                  SelectedItem="{Binding CuentaSeleccionada}"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  Background="#121820"
                  Foreground="#E7EDF5"
                  RowBackground="#121820"
                  AlternatingRowBackground="#18202A"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="Cuenta" Binding="{Binding NumeroCuenta}" Width="*" />
                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoCuenta}" Width="100" />
                <DataGridTextColumn Header="Divisa" Binding="{Binding TipoDivisa}" Width="80" />
                <DataGridTextColumn Header="Banco" Binding="{Binding BancoNombre}" Width="150" />
                <DataGridTextColumn Header="Compañía" Binding="{Binding CompaniaNombre}" Width="150" />
                <DataGridCheckBoxColumn Header="Activa" Binding="{Binding Estado}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Grid.Column="2" Padding="18" Background="#121820" BorderBrush="#26313D" BorderThickness="1" CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding TituloFormulario}" FontSize="19" FontWeight="SemiBold" Foreground="#F3F6FA" Margin="0,0,0,16" />

                    <TextBlock Text="Número de cuenta" />
                    <TextBox Text="{Binding Form.NumeroCuenta, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Tipo de cuenta" />
                    <ComboBox ItemsSource="{Binding TiposCuenta}" SelectedItem="{Binding Form.TipoCuenta}" />

                    <TextBlock Text="Divisa" />
                    <ComboBox ItemsSource="{Binding TiposDivisa}" SelectedItem="{Binding Form.TipoDivisa}" />

                    <TextBlock Text="Banco registrado" />
                    <ComboBox ItemsSource="{Binding Bancos}"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding Form.BancoId}" />

                    <TextBlock Text="Compañía registrada" />
                    <ComboBox ItemsSource="{Binding Companias}"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding Form.CompaniaId}" />

                    <TextBlock Text="País" />
                    <TextBox Text="{Binding Form.Pais, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Provincia" />
                    <TextBox Text="{Binding Form.Provincia, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Nombre dueño" />
                    <TextBox Text="{Binding Form.NombreDueno, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Apellidos dueño" />
                    <TextBox Text="{Binding Form.ApellidosDueno, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox Content="Activa" Foreground="#D7DEE8" IsChecked="{Binding Form.Estado}" Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Editar selección" Command="{Binding EditarCommand}" />
                        <Button Content="Guardar" Command="{Binding GuardarCommand}" Background="#1688F0" Foreground="White" />
                        <Button Content="Eliminar" Command="{Binding EliminarCommand}" />
                        <Button Content="Cancelar" Command="{Binding CancelarCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Text="{Binding Mensaje}" Foreground="#9FB2C8" Margin="0,14,0,0" />
    </Grid>
</UserControl>
