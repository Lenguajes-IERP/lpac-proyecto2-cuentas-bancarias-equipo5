<Window x:Class="SalesPro.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SalesPro.Wpf.ViewModels"
        xmlns:views="clr-namespace:SalesPro.Wpf.Views"
        Title="SalesPro" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="#0F1419">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CuentasBancariasViewModel}">
            <views:CuentasBancariasView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NuevaOrdenViewModel}">
            <views:NuevaOrdenView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#121820" BorderBrush="#26313D" BorderThickness="0,0,0,1" Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="▣  SalesPro" Foreground="#F3F6FA" FontSize="18" FontWeight="SemiBold" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cuentas bancarias" Command="{Binding MostrarCuentasCommand}" Margin="0,0,10,0" Padding="14,8" />
                    <Button Content="Nueva orden" Command="{Binding MostrarNuevaOrdenCommand}" Padding="14,8" />
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentViewModel}" />
    </DockPanel>
</Window>
