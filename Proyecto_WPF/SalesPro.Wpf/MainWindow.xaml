<Window x:Class="SalesPro.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SalesPro.Wpf.ViewModels"
        xmlns:views="clr-namespace:SalesPro.Wpf.Views"
        Title="SalesPro" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        AutomationProperties.Name="Sistema de gestión de cuentas bancarias y órdenes de venta"
        AutomationProperties.HelpText="Aplicación de escritorio con navegación por teclado y nombres accesibles para sus controles principales">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:CuentasBancariasViewModel}">
            <views:CuentasBancariasView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NuevaOrdenViewModel}">
            <views:NuevaOrdenView />
        </DataTemplate>
    </Window.Resources>

    <DockPanel KeyboardNavigation.TabNavigation="Continue">
        <Border DockPanel.Dock="Top" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="SalesPro"
                           Foreground="{DynamicResource HeadingTextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           AutomationProperties.Name="SalesPro" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="ThemeToggleButton"
                            Content="Tema claro"
                            Click="ThemeToggleButton_Click"
                            Margin="0,0,10,0"
                            Padding="14,8"
                            TabIndex="0"
                            ToolTip="Cambiar entre tema claro y tema oscuro"
                            AutomationProperties.Name="Cambiar tema visual"
                            AutomationProperties.HelpText="Alterna el contraste visual de la aplicación entre tema oscuro y tema claro" />
                    <Button Content="Cuentas bancarias"
                            Command="{Binding MostrarCuentasCommand}"
                            Margin="0,0,10,0"
                            Padding="14,8"
                            TabIndex="1"
                            ToolTip="Abrir el actualizador de cuentas bancarias"
                            AutomationProperties.Name="Abrir gestión de cuentas bancarias"
                            AutomationProperties.HelpText="Muestra la pantalla para buscar, crear, editar y eliminar cuentas bancarias" />
                    <Button Content="Nueva orden"
                            Command="{Binding MostrarNuevaOrdenCommand}"
                            Padding="14,8"
                            TabIndex="2"
                            ToolTip="Abrir registro de orden de venta"
                            AutomationProperties.Name="Abrir nueva orden de venta"
                            AutomationProperties.HelpText="Muestra la pantalla maestro detalle para registrar una orden de venta" />
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl Content="{Binding CurrentViewModel}" />
    </DockPanel>
</Window>
