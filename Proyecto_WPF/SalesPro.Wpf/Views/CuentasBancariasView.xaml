<UserControl x:Class="SalesPro.Wpf.Views.CuentasBancariasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             KeyboardNavigation.TabNavigation="Continue"
             AutomationProperties.Name="Gestión de cuentas bancarias"
             AutomationProperties.HelpText="Pantalla para buscar, crear, editar y eliminar cuentas bancarias">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LabelTextBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Template" Value="{StaticResource ThemedComboBoxTemplate}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,7" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="1.15*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,18">
            <TextBlock Text="Gestión de cuentas bancarias"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{DynamicResource HeadingTextBrush}"
                       Margin="0,0,28,0"
                       AutomationProperties.HeadingLevel="Level1" />
            <TextBox Width="260"
                     Text="{Binding Buscar, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     TabIndex="0"
                     ToolTip="Digite texto para filtrar cuentas bancarias"
                     AutomationProperties.Name="Texto de búsqueda de cuentas bancarias"
                     AutomationProperties.HelpText="Permite filtrar cuentas por número, banco, compañía o dueño" />
            <Button Content="Buscar / recargar"
                    Command="{Binding CargarCommand}"
                    TabIndex="1"
                    ToolTip="Buscar cuentas bancarias"
                    AutomationProperties.Name="Buscar o recargar cuentas bancarias" />
            <Button Content="Nueva"
                    Command="{Binding NuevaCommand}"
                    TabIndex="2"
                    ToolTip="Limpiar formulario para crear una cuenta bancaria"
                    AutomationProperties.Name="Crear nueva cuenta bancaria" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding Cuentas}"
                  SelectedItem="{Binding CuentaSeleccionada}"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  Background="{DynamicResource CardBackgroundBrush}"
                  Foreground="{DynamicResource TextBrush}"
                  RowBackground="{DynamicResource DataGridRowBrush}"
                  AlternatingRowBackground="{DynamicResource DataGridAlternatingRowBrush}"
                  GridLinesVisibility="Horizontal"
                  TabIndex="3"
                  AutomationProperties.Name="Tabla de cuentas bancarias"
                  AutomationProperties.HelpText="Listado de cuentas bancarias registradas. Seleccione una fila para editarla o eliminarla">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="Cuenta" Binding="{Binding NumeroCuenta}" Width="*" />
                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoCuenta}" Width="100" />
                <DataGridTextColumn Header="Divisa" Binding="{Binding TipoDivisa}" Width="80" />
                <DataGridTextColumn Header="Banco" Binding="{Binding BancoNombre}" Width="150" />
                <DataGridTextColumn Header="Compañía" Binding="{Binding CompaniaNombre}" Width="150" />
                <DataGridCheckBoxColumn Header="Activa" Binding="{Binding Estado}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Grid.Column="2" Padding="18" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding TituloFormulario}"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HeadingTextBrush}"
                               Margin="0,0,0,16"
                               AutomationProperties.HeadingLevel="Level2" />

                    <TextBlock Text="Número de cuenta" />
                    <TextBox Text="{Binding Form.NumeroCuenta, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="4"
                             ToolTip="Digite el número de cuenta bancaria"
                             AutomationProperties.Name="Número de cuenta bancaria" />

                    <TextBlock Text="Tipo de cuenta" />
                    <ComboBox ItemsSource="{Binding TiposCuenta}"
                              SelectedItem="{Binding Form.TipoCuenta}"
                              TabIndex="5"
                              AutomationProperties.Name="Tipo de cuenta bancaria" />

                    <TextBlock Text="Divisa" />
                    <ComboBox ItemsSource="{Binding TiposDivisa}"
                              SelectedItem="{Binding Form.TipoDivisa}"
                              TabIndex="6"
                              AutomationProperties.Name="Tipo de divisa" />

                    <TextBlock Text="Banco registrado" />
                    <ComboBox ItemsSource="{Binding Bancos}"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding Form.BancoId}"
                              TabIndex="7"
                              AutomationProperties.Name="Banco registrado" />

                    <TextBlock Text="Compañía registrada" />
                    <ComboBox ItemsSource="{Binding Companias}"
                              DisplayMemberPath="Nombre"
                              SelectedValuePath="Id"
                              SelectedValue="{Binding Form.CompaniaId}"
                              TabIndex="8"
                              AutomationProperties.Name="Compañía registrada" />

                    <TextBlock Text="País" />
                    <TextBox Text="{Binding Form.Pais, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="9"
                             AutomationProperties.Name="País de la cuenta bancaria" />

                    <TextBlock Text="Provincia" />
                    <TextBox Text="{Binding Form.Provincia, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="10"
                             AutomationProperties.Name="Provincia de la cuenta bancaria" />

                    <TextBlock Text="Nombre dueño" />
                    <TextBox Text="{Binding Form.NombreDueno, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="11"
                             AutomationProperties.Name="Nombre del dueño de la cuenta" />

                    <TextBlock Text="Apellidos dueño" />
                    <TextBox Text="{Binding Form.ApellidosDueno, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="12"
                             AutomationProperties.Name="Apellidos del dueño de la cuenta" />

                    <CheckBox Content="Activa"
                              Foreground="{DynamicResource LabelTextBrush}"
                              IsChecked="{Binding Form.Estado}"
                              TabIndex="13"
                              AutomationProperties.Name="Cuenta bancaria activa" />
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Editar selección"
                                Command="{Binding EditarCommand}"
                                TabIndex="14"
                                AutomationProperties.Name="Editar cuenta seleccionada" />
                        <Button Content="Guardar"
                                Command="{Binding GuardarCommand}"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                TabIndex="15"
                                AutomationProperties.Name="Guardar cuenta bancaria" />
                        <Button Content="Eliminar"
                                Command="{Binding EliminarCommand}"
                                TabIndex="16"
                                AutomationProperties.Name="Eliminar cuenta bancaria seleccionada" />
                        <Button Content="Cancelar"
                                Command="{Binding CancelarCommand}"
                                TabIndex="17"
                                AutomationProperties.Name="Cancelar edición de cuenta bancaria" />
                    </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="3"
                   Text="{Binding Mensaje}"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Margin="0,14,0,0"
                   AutomationProperties.LiveSetting="Polite"
                   AutomationProperties.Name="Mensaje de estado de cuentas bancarias" />
    </Grid>
</UserControl>
