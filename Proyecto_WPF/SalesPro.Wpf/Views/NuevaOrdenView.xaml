<UserControl x:Class="SalesPro.Wpf.Views.NuevaOrdenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             KeyboardNavigation.TabNavigation="Continue"
             AutomationProperties.Name="Registro de nueva orden de venta"
             AutomationProperties.HelpText="Pantalla maestro detalle para registrar productos en una orden de venta">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextoSecundario}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,7" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.1*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="1*" MinWidth="360" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.ColumnSpan="3"
                   Text="Nueva orden de venta"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{StaticResource TextoPrincipal}"
                   Margin="0,0,0,20"
                   AutomationProperties.HeadingLevel="Level1" />

        <Border Grid.Row="1" Grid.Column="0" Padding="18" Background="{StaticResource FondoPanel}" BorderBrush="{StaticResource Borde}" BorderThickness="1" CornerRadius="10" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="160" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                    <TextBlock Text="Cliente seleccionado" />
                    <TextBox Text="{Binding ClienteResumen, Mode=OneWay}"
                             IsReadOnly="True"
                             TabIndex="0"
                             ToolTip="Cliente asociado a la orden"
                             AutomationProperties.Name="Cliente seleccionado"
                             AutomationProperties.HelpText="Muestra el cliente asociado a la orden de venta" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock Text="Empleado Id" />
                    <TextBox Text="{Binding EmpleadoId, UpdateSourceTrigger=PropertyChanged}"
                             TabIndex="2"
                             ToolTip="Identificador del empleado que registra la orden"
                             AutomationProperties.Name="Identificador del empleado" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Seleccionar _Cliente"
                        Click="AbrirBusquedaCliente_Click"
                        VerticalAlignment="Center"
                        Background="{StaticResource Borde}"
                        Foreground="{StaticResource TextoSecundario}"
                        TabIndex="1"
                        ToolTip="Abrir ventana para buscar y seleccionar cliente"
                        AutomationProperties.Name="Seleccionar cliente"
                        AutomationProperties.HelpText="Abre la búsqueda de clientes para asociar uno a la orden" />

                <Button Grid.Column="3"
                        Content="_Buscar y Agregar Producto..."
                        Click="AbrirBusqueda_Click"
                        VerticalAlignment="Center"
                        Background="{StaticResource Acento}"
                        Foreground="White"
                        TabIndex="3"
                        ToolTip="Abrir ventana para buscar productos y agregarlos a la orden"
                        AutomationProperties.Name="Buscar y agregar producto"
                        AutomationProperties.HelpText="Abre la búsqueda de productos para seleccionar cantidad y agregar detalle a la orden" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Top" Margin="0,15,0,0">
            <TextBlock Text="{Binding Mensaje}"
                       Foreground="{StaticResource TextoTenue}"
                       TextWrapping="Wrap"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="Mensaje de estado de la orden" />
        </StackPanel>

        <Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="3" Padding="18" Background="{StaticResource FondoPanel}" BorderBrush="{StaticResource Borde}" BorderThickness="1" CornerRadius="10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,18,0,0">
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Subtotal" />
                        <TextBlock Text="{Binding Subtotal, StringFormat=₡{0:N2}}" HorizontalAlignment="Right" Foreground="{StaticResource TextoPrincipal}" AutomationProperties.Name="Subtotal de la orden" />
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="IVA estimado" />
                        <TextBlock Text="{Binding ImpuestoEstimado, StringFormat=₡{0:N2}}" HorizontalAlignment="Right" Foreground="{StaticResource TextoPrincipal}" AutomationProperties.Name="IVA estimado de la orden" />
                    </Grid>
                    <Separator Margin="0,8" />
                    <Grid Margin="0,0,0,18">
                        <TextBlock Text="Total estimado" FontWeight="Bold" />
                        <TextBlock Text="{Binding TotalEstimado, StringFormat=₡{0:N2}}" HorizontalAlignment="Right" Foreground="{StaticResource TextoPrincipal}" FontWeight="Bold" AutomationProperties.Name="Total estimado de la orden" />
                    </Grid>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="+" Command="{Binding IncrementarCommand}" Width="42" TabIndex="5" ToolTip="Incrementar cantidad" AutomationProperties.Name="Incrementar cantidad del producto seleccionado" />
                        <Button Content="-" Command="{Binding DecrementarCommand}" Width="42" TabIndex="6" ToolTip="Disminuir cantidad" AutomationProperties.Name="Disminuir cantidad del producto seleccionado" />
                        <Button Content="_Remover" Command="{Binding RemoverProductoCommand}" TabIndex="7" AutomationProperties.Name="Remover producto seleccionado de la orden" />
                    </StackPanel>
                    <Button Content="_Procesar orden" Command="{Binding ProcesarOrdenCommand}" Background="{StaticResource Acento}" Foreground="White" Margin="0,12,0,0" TabIndex="8" AutomationProperties.Name="Procesar orden de venta" />
                    <Button Content="_Limpiar" Command="{Binding LimpiarCommand}" Margin="0,8,0,0" TabIndex="9" AutomationProperties.Name="Limpiar orden de venta" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Detalle de orden" FontSize="19" FontWeight="SemiBold" Foreground="{StaticResource TextoPrincipal}" Margin="0,0,0,12" AutomationProperties.HeadingLevel="Level2" />
                    <DataGrid ItemsSource="{Binding Detalles}"
                              SelectedItem="{Binding DetalleSeleccionado}"
                              MinHeight="360"
                              TabIndex="4"
                              AutomationProperties.Name="Tabla de detalles de la orden"
                              AutomationProperties.HelpText="Lista de productos agregados a la orden. Seleccione una fila para modificar cantidad o removerla">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="2*" MinWidth="90" />
                            <DataGridTextColumn Header="Cant." Binding="{Binding Cantidad}" Width="0.6*" MinWidth="48" />
                            <DataGridTextColumn Header="Precio" Binding="{Binding PrecioUnitario, StringFormat=₡{0:N2}}" Width="*" MinWidth="80" />
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=₡{0:N2}}" Width="*" MinWidth="85" />
                            <DataGridTextColumn Header="IVA" Binding="{Binding ImpuestoEstimado, StringFormat=₡{0:N2}}" Width="*" MinWidth="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
