<Window x:Class="SalesPro.Wpf.Views.BuscarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Cliente" Height="460" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        KeyboardNavigation.TabNavigation="Continue"
        AutomationProperties.Name="Búsqueda de cliente"
        AutomationProperties.HelpText="Ventana para buscar y seleccionar el cliente asociado a la orden">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LabelTextBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource DataGridHeaderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LabelTextBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Buscar cliente por nombre, apellidos, identificaciÃ³n o correo:"
                       FontWeight="SemiBold"
                       FontSize="14"
                       AutomationProperties.HeadingLevel="Level1" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding ClienteBusqueda, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,10,12"
                         TabIndex="0"
                         ToolTip="Digite nombre, apellidos, identificaciÃ³n o correo del cliente"
                         AutomationProperties.Name="Texto de búsqueda de cliente" />
                <Button Grid.Column="1"
                        Content="Buscar"
                        Command="{Binding BuscarClientesCommand}"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0"
                        TabIndex="1"
                        AutomationProperties.Name="Buscar clientes" />
            </Grid>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ClientesEncontrados}"
                  SelectedItem="{Binding ClienteSeleccionado}"
                  IsReadOnly="True"
                  Background="{DynamicResource CardBackgroundBrush}"
                  Foreground="{DynamicResource TextBrush}"
                  RowBackground="{DynamicResource DataGridRowBrush}"
                  AlternatingRowBackground="{DynamicResource DataGridAlternatingRowBrush}"
                  HeadersVisibility="Column"
                  Margin="0,0,0,15"
                  TabIndex="2"
                  AutomationProperties.Name="Tabla de clientes encontrados"
                  AutomationProperties.HelpText="Seleccione el cliente que se asociarÃ¡ a la orden">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70" />
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="150" />
                <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="180" />
                <DataGridTextColumn Header="IdentificaciÃ³n" Binding="{Binding NumeroIdentificacion}" Width="130" />
                <DataGridTextColumn Header="Correo" Binding="{Binding Email}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Mensaje}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       VerticalAlignment="Center"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="Mensaje de búsqueda de cliente" />

            <Button Grid.Column="1"
                    Content="Cancelar"
                    Click="Cerrar_Click"
                    Margin="0,0,10,0"
                    Background="{DynamicResource SecondaryButtonBrush}"
                    Foreground="{DynamicResource TextBrush}"
                    TabIndex="3"
                    AutomationProperties.Name="Cancelar búsqueda de cliente" />
            <Button Grid.Column="2"
                    Content="Seleccionar Cliente"
                    Click="Seleccionar_Click"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    TabIndex="4"
                    AutomationProperties.Name="Seleccionar cliente para la orden" />
        </Grid>
    </Grid>
</Window>
