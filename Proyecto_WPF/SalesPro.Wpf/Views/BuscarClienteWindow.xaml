<Window x:Class="SalesPro.Wpf.Views.BuscarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Cliente" Height="460" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="#0F141A"
        Foreground="#E7EDF5"
        KeyboardNavigation.TabNavigation="Continue"
        AutomationProperties.Name="Búsqueda de cliente"
        AutomationProperties.HelpText="Ventana para buscar y seleccionar el cliente asociado a la orden">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D7DEE8" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Buscar cliente por nombre, apellidos, identificación o correo:"
                       FontWeight="SemiBold"
                       FontSize="14"
                       AutomationProperties.HeadingLevel="Level1" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding ClienteBusqueda, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,10,12"
                         TabIndex="0"
                         ToolTip="Digite nombre, apellidos, identificación o correo del cliente"
                         AutomationProperties.Name="Texto de búsqueda de cliente" />
                <Button Grid.Column="1"
                        Content="Buscar"
                        Command="{Binding BuscarClientesCommand}"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0"
                        TabIndex="1"
                        AutomationProperties.Name="Buscar clientes" />
            </Grid>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ClientesEncontrados}"
                  SelectedItem="{Binding ClienteSeleccionado}"
                  IsReadOnly="True"
                  Background="#121820"
                  Foreground="#E7EDF5"
                  RowBackground="#121820"
                  AlternatingRowBackground="#18202A"
                  HeadersVisibility="Column"
                  Margin="0,0,0,15"
                  TabIndex="2"
                  AutomationProperties.Name="Tabla de clientes encontrados"
                  AutomationProperties.HelpText="Seleccione el cliente que se asociará a la orden">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70" />
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="150" />
                <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="180" />
                <DataGridTextColumn Header="Identificación" Binding="{Binding NumeroIdentificacion}" Width="130" />
                <DataGridTextColumn Header="Correo" Binding="{Binding Email}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Mensaje}"
                       Foreground="#9FB2C8"
                       VerticalAlignment="Center"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="Mensaje de búsqueda de cliente" />

            <Button Grid.Column="1"
                    Content="Cancelar"
                    Click="Cerrar_Click"
                    Margin="0,0,10,0"
                    Background="#26313D"
                    Foreground="#E7EDF5"
                    TabIndex="3"
                    AutomationProperties.Name="Cancelar búsqueda de cliente" />
            <Button Grid.Column="2"
                    Content="Seleccionar Cliente"
                    Click="Seleccionar_Click"
                    Background="#1688F0"
                    Foreground="White"
                    TabIndex="4"
                    AutomationProperties.Name="Seleccionar cliente para la orden" />
        </Grid>
    </Grid>
</Window>
