<Window x:Class="SalesPro.Wpf.Views.BuscarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Cliente" Height="460" Width="720"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource FondoApp}"
        Foreground="{DynamicResource TextoPrincipal}"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="Búsqueda de cliente"
        AutomationProperties.HelpText="Ventana para buscar y seleccionar el cliente asociado a la orden">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextoSecundario}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Buscar cliente por nombre, apellidos, identificación o correo:"
                       FontWeight="SemiBold"
                       FontSize="14"
                       AutomationProperties.HeadingLevel="Level1" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding ClienteBusqueda, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,10,12"
                         TabIndex="0"
                         ToolTip="Digite nombre, apellidos, identificación o correo del cliente"
                         AutomationProperties.Name="Texto de búsqueda de cliente" />
                <Button Grid.Column="1"
                        Content="_Buscar"
                        Command="{Binding BuscarClientesCommand}"
                        IsDefault="True"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0"
                        TabIndex="1"
                        Background="{DynamicResource FondoPanel}"
                        Foreground="{DynamicResource TextoPrincipal}"
                        BorderBrush="{DynamicResource Borde}"
                        AutomationProperties.Name="Buscar clientes" />
            </Grid>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ClientesEncontrados}"
                  SelectedItem="{Binding ClienteSeleccionado}"
                  Margin="0,0,0,15"
                  TabIndex="2"
                  AutomationProperties.Name="Tabla de clientes encontrados"
                  AutomationProperties.HelpText="Seleccione el cliente que se asociará a la orden. Presione Enter para confirmar la selección">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="0.5*" MinWidth="55" />
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" MinWidth="120" />
                <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="1.3*" MinWidth="140" />
                <DataGridTextColumn Header="Identificación" Binding="{Binding NumeroIdentificacion}" Width="*" MinWidth="110" />
                <DataGridTextColumn Header="Correo" Binding="{Binding Email}" Width="1.5*" MinWidth="130" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Mensaje}"
                       Foreground="{DynamicResource TextoTenue}"
                       VerticalAlignment="Center"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="Mensaje de búsqueda de cliente" />

            <Button Grid.Column="1"
                    Content="_Cancelar"
                    Click="Cerrar_Click"
                    IsCancel="True"
                    Margin="0,0,10,0"
                    Background="{DynamicResource FondoPanel}"
                    Foreground="{DynamicResource TextoPrincipal}"
                    BorderBrush="{DynamicResource Borde}"
                    TabIndex="3"
                    AutomationProperties.Name="Cancelar búsqueda de cliente" />
            <Button Grid.Column="2"
                    Content="_Seleccionar Cliente"
                    Click="Seleccionar_Click"
                    Background="{DynamicResource Acento}"
                    Foreground="{DynamicResource TextoSobreAcento}"
                    BorderBrush="{DynamicResource Borde}"
                    TabIndex="4"
                    AutomationProperties.Name="Seleccionar cliente para la orden" />
        </Grid>
    </Grid>
</Window>
