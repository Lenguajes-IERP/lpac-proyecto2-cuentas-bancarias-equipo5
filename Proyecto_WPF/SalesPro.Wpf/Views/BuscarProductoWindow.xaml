<Window x:Class="SalesPro.Wpf.Views.BuscarProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Producto" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource LabelTextBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource DataGridHeaderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource LabelTextBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Buscar producto por nombre o cÃ³digo:" FontWeight="SemiBold" FontSize="14" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding ProductoBusqueda, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,10,12" />
                <Button Grid.Column="1" Content="Buscar" Command="{Binding BuscarProductosCommand}" VerticalAlignment="Top" Margin="0,5,0,0" />
            </Grid>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ProductosEncontrados}"
                  SelectedItem="{Binding ProductoSeleccionado}"
                  IsReadOnly="True"
                  Background="{DynamicResource CardBackgroundBrush}"
                  Foreground="{DynamicResource TextBrush}"
                  RowBackground="{DynamicResource DataGridRowBrush}"
                  AlternatingRowBackground="{DynamicResource DataGridAlternatingRowBrush}"
                  HeadersVisibility="Column"
                  Margin="0,0,0,15">
            <DataGrid.Columns>
                <DataGridTextColumn Header="CÃ³digo" Binding="{Binding CodigoBarra}" Width="100" />
                <DataGridTextColumn Header="Producto" Binding="{Binding NombreEtiqueta}" Width="*" />
                <DataGridTextColumn Header="Stock" Binding="{Binding ExistenciaEnStock}" Width="80" />
                <DataGridTextColumn Header="Precio" Binding="{Binding PrecioNeto, StringFormat=â‚¡{0:N2}}" Width="120" />
                <DataGridCheckBoxColumn Header="IVA" Binding="{Binding TieneImpuesto}" Width="60" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Cantidad:" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox Grid.Column="1" Text="{Binding CantidadProducto, UpdateSourceTrigger=PropertyChanged}" Margin="0" VerticalContentAlignment="Center" />
            
            <TextBlock Grid.Column="2" Text="{Binding Mensaje}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" Margin="15,0,0,0" />

            <Button Grid.Column="3" Content="Cancelar" Click="Cerrar_Click" Margin="0,0,10,0" Background="{DynamicResource SecondaryButtonBrush}" Foreground="{DynamicResource TextBrush}" />
            <Button Grid.Column="4" Content="Agregar Producto" Click="Agregar_Click" Background="{DynamicResource PrimaryBrush}" Foreground="{DynamicResource PrimaryTextBrush}" />
        </Grid>
    </Grid>
</Window>
