<Window x:Class="SalesPro.Wpf.Views.BuscarProductoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Producto" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource FondoApp}"
        Foreground="{DynamicResource TextoPrincipal}"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="Búsqueda de producto"
        AutomationProperties.HelpText="Ventana para buscar un producto, indicar la cantidad y agregarlo a la orden">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextoSecundario}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,5,0,12" />
            <Setter Property="Padding" Value="8" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Buscar producto por nombre o código:"
                       FontWeight="SemiBold"
                       FontSize="14"
                       AutomationProperties.HeadingLevel="Level1" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding ProductoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,10,12"
                         TabIndex="0"
                         ToolTip="Digite el nombre o el código del producto"
                         AutomationProperties.Name="Texto de búsqueda de producto" />
                <Button Grid.Column="1"
                        Content="_Buscar"
                        Command="{Binding BuscarProductosCommand}"
                        IsDefault="True"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0"
                        TabIndex="1"
                       
                        Foreground="{DynamicResource TextoPrincipal}"
                       
                        AutomationProperties.Name="Buscar productos" />
            </Grid>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ProductosEncontrados}"
                  SelectedItem="{Binding ProductoSeleccionado}"
                  Margin="0,0,0,15"
                  TabIndex="2"
                  AutomationProperties.Name="Tabla de productos encontrados"
                  AutomationProperties.HelpText="Seleccione el producto que se agregará a la orden">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Código" Binding="{Binding CodigoBarra}" Width="*" MinWidth="90" />
                <DataGridTextColumn Header="Producto" Binding="{Binding NombreEtiqueta}" Width="2*" MinWidth="120" />
                <DataGridTextColumn Header="Stock" Binding="{Binding ExistenciaEnStock}" Width="0.7*" MinWidth="65" />
                <DataGridTextColumn Header="Precio" Binding="{Binding PrecioNeto, StringFormat=₡{0:N2}}" Width="*" MinWidth="95" />
                <DataGridCheckBoxColumn Header="IVA" Binding="{Binding TieneImpuesto}" Width="0.6*" MinWidth="55" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Cantidad:" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox x:Name="CantidadBox"
                     Grid.Column="1"
                     Text="{Binding CantidadProducto, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0"
                     VerticalContentAlignment="Center"
                     TabIndex="3"
                     ToolTip="Cantidad de unidades del producto a agregar"
                     AutomationProperties.Name="Cantidad del producto" />

            <TextBlock Grid.Column="2"
                       Text="{Binding Mensaje}"
                       Foreground="{DynamicResource TextoTenue}"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.Name="Mensaje de búsqueda de producto" />

            <Button Grid.Column="3"
                    Content="_Cancelar"
                    Click="Cerrar_Click"
                    IsCancel="True"
                    Margin="0,0,10,0"
                   
                    Foreground="{DynamicResource TextoPrincipal}"
                   
                    TabIndex="4"
                    AutomationProperties.Name="Cancelar búsqueda de producto" />
            <Button Grid.Column="4"
                    Content="A_gregar producto" Style="{DynamicResource BotonAcento}"
                    Click="Agregar_Click"
                   
                   
                   
                    TabIndex="5"
                    AutomationProperties.Name="Agregar producto a la orden" />
        </Grid>
    </Grid>
</Window>
