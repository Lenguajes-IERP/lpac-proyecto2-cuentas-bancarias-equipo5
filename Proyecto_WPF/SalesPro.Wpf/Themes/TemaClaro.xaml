    <SolidColorBrush x:Key="FondoApp" Color="#F4F6F9" />
    <SolidColorBrush x:Key="FondoPanel" Color="#FFFFFF" />
    <SolidColorBrush x:Key="FondoHeader" Color="#E3E8EF" />
    <SolidColorBrush x:Key="Borde" Color="#C3CCD8" />
    <SolidColorBrush x:Key="TextoPrincipal" Color="#0F1720" />
    <SolidColorBrush x:Key="TextoSecundario" Color="#28323F" />
    <SolidColorBrush x:Key="TextoTenue" Color="#4A586B" />
    <SolidColorBrush x:Key="Acento" Color="#0A66C2" />
    <SolidColorBrush x:Key="TextoSobreAcento" Color="#FFFFFF" />
    <SolidColorBrush x:Key="FilaAlterna" Color="#EEF2F7" />
    <SolidColorBrush x:Key="Foco" Color="#0A66C2" />
</ResourceDictionary>
