<Application x:Class="SalesPro.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SalesPro.Wpf"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Slot 0: tema activo (lo inyecta TemaService; por defecto Claro). -->
                <ResourceDictionary Source="Themes/TemaClaro.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ====== FOCO VISIBLE REFORZADO (doble contorno, WCAG 2.4.11/2.4.13) ======
                 Traduce a WPF el foco de InclusaSalud: anillo grueso que se ve sobre
                 cualquier fondo. Contorno interior del color del fondo + anillo de foco. -->
            <Style x:Key="FocoAccesible">
                <Setter Property="Control.FocusVisualStyle">
                    <Setter.Value>
                        <Style>
                            <Setter Property="Control.Template">
                                <Setter.Value>
                                    <ControlTemplate>
                                        <Grid Margin="-3">
                                            <Rectangle StrokeThickness="5"
                                                       Stroke="{DynamicResource FondoApp}"
                                                       RadiusX="4" RadiusY="4"
                                                       SnapsToDevicePixels="True" />
                                            <Rectangle StrokeThickness="3"
                                                       Stroke="{DynamicResource Foco}"
                                                       RadiusX="4" RadiusY="4"
                                                       SnapsToDevicePixels="True" />
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Aplica el foco reforzado por defecto a los controles interactivos -->
            <Style TargetType="Button" BasedOn="{StaticResource FocoAccesible}" />
            <Style TargetType="ComboBox" BasedOn="{StaticResource FocoAccesible}" />
            <Style TargetType="TextBox" BasedOn="{StaticResource FocoAccesible}" />
            <Style TargetType="CheckBox" BasedOn="{StaticResource FocoAccesible}" />
            <Style TargetType="DataGridRow" BasedOn="{StaticResource FocoAccesible}">
                <Setter Property="MinHeight" Value="30" />
            </Style>

            <!-- ====== Encabezados de columna con contraste ====== -->
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{DynamicResource FondoHeader}" />
                <Setter Property="Foreground" Value="{DynamicResource TextoPrincipal}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="BorderBrush" Value="{DynamicResource Borde}" />
                <Setter Property="BorderThickness" Value="0,0,1,1" />
            </Style>

            <!-- ====== Celdas: selección de ALTO CONTRASTE y bien visible ====== -->
            <Style TargetType="DataGridCell">
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="FontSize" Value="13" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Acento}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextoSobreAcento}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Fila seleccionada: resalte fuerte (borde grueso + fondo de acento) -->
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="{DynamicResource FondoPanel}" />
                <Setter Property="Foreground" Value="{DynamicResource TextoSecundario}" />
                <Setter Property="RowBackground" Value="{DynamicResource FondoPanel}" />
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource FilaAlterna}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Borde}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Borde}" />
                <Setter Property="HeadersVisibility" Value="Column" />
                <Setter Property="AutoGenerateColumns" Value="False" />
                <Setter Property="IsReadOnly" Value="True" />
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
                <Setter Property="ColumnWidth" Value="Auto" />
                <Setter Property="SelectionUnit" Value="FullRow" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
