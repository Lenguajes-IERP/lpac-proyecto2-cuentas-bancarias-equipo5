<Application x:Class="SalesPro.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SalesPro.Wpf"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ============ Paleta central (tema oscuro accesible) ============ -->
        <SolidColorBrush x:Key="FondoApp" Color="#0F1419" />
        <SolidColorBrush x:Key="FondoPanel" Color="#121820" />
        <SolidColorBrush x:Key="FondoHeader" Color="#1C2733" />
        <SolidColorBrush x:Key="Borde" Color="#26313D" />
        <SolidColorBrush x:Key="TextoPrincipal" Color="#F3F6FA" />
        <SolidColorBrush x:Key="TextoSecundario" Color="#D7DEE8" />
        <SolidColorBrush x:Key="TextoTenue" Color="#9FB2C8" />
        <SolidColorBrush x:Key="Acento" Color="#1688F0" />
        <SolidColorBrush x:Key="FilaAlterna" Color="#18202A" />

        <!-- ============ Encabezados de columna (contraste WCAG AA) ============ -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource FondoHeader}" />
            <Setter Property="Foreground" Value="{StaticResource TextoPrincipal}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="BorderBrush" Value="{StaticResource Borde}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <!-- ============ Celdas: padding y foco/selección de alto contraste ============ -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Acento}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="30" />
        </Style>

        <!-- ============ DataGrid base: tema oscuro + scroll horizontal de respaldo ============ -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource FondoPanel}" />
            <Setter Property="Foreground" Value="{StaticResource TextoSecundario}" />
            <Setter Property="RowBackground" Value="{StaticResource FondoPanel}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource FilaAlterna}" />
            <Setter Property="BorderBrush" Value="{StaticResource Borde}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Borde}" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ColumnWidth" Value="Auto" />
        </Style>

    </Application.Resources>
</Application>
